[run]
source = src/mcp_server_fetch
omit = 
    */tests/*
    */__pycache__/*
    */.pytest_cache/*
    */__init__.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    raise ImportError
    except ImportError
    if TYPE_CHECKING:

[html]
directory = htmlcov